datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  role      String   @default("Student") // Admin, Editor, Author, Student
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]
}

model Post {
  id          String     @id @default(uuid())
  title       String
  slug        String     @unique
  content     String
  excerpt     String?
  published   Boolean    @default(false)
  publishedAt DateTime?
  scheduledAt DateTime?
  featured    Boolean    @default(false)
  authorId    String
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  views       Int        @default(0)
  coverImage  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  comments    Comment[]
  seo         SEO?
  categories  Category[]
  tags        Tag[]
}

model Category {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  description String?
  parentId    String?
  parent      Category?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: Cascade)
  children    Category[] @relation("SubCategories")
  posts       Post[]
}

model Tag {
  id    String @id @default(uuid())
  name  String
  slug  String @unique
  posts Post[]
}

model Comment {
  id           String   @id @default(uuid())
  content      String
  status       String   @default("Pending") // Approved, Pending, Rejected, Spam
  postId       String
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorName   String
  authorEmail  String
  authorAvatar String?
  createdAt    DateTime @default(now())
}

model Media {
  id        String   @id @default(uuid())
  fileName  String
  fileUrl   String
  fileSize  Int
  fileType  String
  bucket    String
  createdAt DateTime @default(now())
}

model SEO {
  id            String  @id @default(uuid())
  postId        String  @unique
  post          Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  title         String?
  description   String?
  canonicalUrl  String?
  ogImage       String?
  twitterCard   String?
  schemaMarkup  String?
}

model Roadmap {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String?
  icon        String?
  color       String?
  category    String?
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Recipe {
  id           String   @id @default(uuid())
  title        String
  slug         String   @unique
  description  String?
  language     String   @default("typescript")
  code         String?
  dependencies String?
  aiPrompt     String?
  bestPractices String?
  category     String?
  published    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model FAQ {
  id        String   @id @default(uuid())
  question  String
  answer    String?
  order     Int      @default(0)
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
